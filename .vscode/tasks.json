{
    "version": "2.0.0",
    "tasks": [
         {
            "label": "Set up environment",
            "type": "shell",
            "command": "uv sync --all-extras",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run tests",
            "type": "shell",
            "command": "uv run pytest --cov=.",
            "problemMatcher": []
        },
        {
            "label": "Build EXE",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Remove-Item -Recurse -Force build/*; uv run pyinstaller --onefile --name stock_scanner --distpath build --add-data=\"stock_scanner/ui/main.qml:ui\" stock_scanner/main.py"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}