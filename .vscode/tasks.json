{
    "version": "2.0.0",
    "tasks": [
         {
            "label": "Set up environment",
            "type": "shell",
            "command": "poetry install",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Format code",
            "type": "shell",
            "command": "poetry run black .; poetry run isort .",
            "problemMatcher": []
        },
        {
            "label": "Lint",
            "type": "shell",
            "command": "poetry run flake8 .; poetry run mypy .",
            "problemMatcher": []
        },
        {
            "label": "Run tests",
            "type": "shell",
            "command": "poetry run pytest --cov=.",
            "problemMatcher": []
        },
        {
            "label": "Run main.py",
            "type": "shell",
            "command": "python",
            "args": [
                "-m", "stock_scanner.main"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Open report",
            "type": "shell",
            "command": "start",
            "args": [
                "report.html"
            ],
            "problemMatcher": []
        },
    ]
}