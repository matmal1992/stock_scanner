{
    "version": "2.0.0",
    "tasks": [
         {
            "label": "Set up environment",
            "type": "shell",
            "command": [ 
                "python -m pip install uv;",
                "python -m uv sync --all-extras; python -m uv run pre-commit install"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run tests",
            "type": "shell",
            "command": "python -m uv run pytest --cov=.",
            "problemMatcher": []
        },
        {
            "label": "Build EXE",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Remove-Item -Recurse -Force build/*; python -m uv run pyinstaller --onefile --name stock_scanner --distpath build --add-data=\"stock_scanner/ui/main.qml:ui\" stock_scanner/main.py"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}