{
    "version": "2.0.0",
    "tasks": [
         {
            "label": "Set up environment",
            "type": "shell",
            "command": "uv sync",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Run tests",
            "type": "shell",
            "command": "uv run pytest --cov=.",
            "problemMatcher": []
        },
        {
            "label": "Run main.py",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "python",
                "-m",
                "stock_scanner.main"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}