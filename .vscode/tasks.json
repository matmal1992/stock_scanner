{
    "version": "2.0.0",
    "tasks": [
         {
            "label": "Install dependencies",
            "type": "shell",
            "command": "poetry install || (poetry add pandas numpy yfinance tqdm pyarrow pyside6 && poetry add --dev black isort flake8 mypy pytest coverage pre-commit)",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Format code",
            "type": "shell",
            "command": "poetry run black .; poetry run isort .",
            "problemMatcher": []
        },
        {
            "label": "Lint",
            "type": "shell",
            "command": "poetry run flake8 . && poetry run mypy .",
            "problemMatcher": []
        },
        {
            "label": "Run tests",
            "type": "shell",
            "command": "poetry run pytest --cov=.",
            "problemMatcher": []
        },
        {
            "label": "Run main.py",
            "type": "shell",
            "command": "python",
            "args": [
                "main.py"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Open report",
            "type": "shell",
            "command": "start",
            "args": [
                "report.html"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run project",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Run main.py",
                "Open report"
            ]
        }

    ]
}